.group-box {
    background-color: rgba(40, 40, 40, 1);
    border-radius: 5px;
    padding: 10px;
    margin: 5px;
}

.audio-bg
{
    background-color: rgba(0, 0, 0, 0.1);
    border-radius: 4px;
    padding: 6px;
}

.core-init-root
{
    padding: 4px;
}

.core-init-title
{
    font-size: 14px;
    -unity-font-style: bold;
}

.core-init-setup-button
{
    background-color: rgba(50, 101, 50, 1);
}

.core-init-setup-button:hover
{
    background-color: rgba(70, 145, 60, 1);
}